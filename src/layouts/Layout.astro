---
// Aquí recibimos el título que le pasamos desde index.astro
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Estos estilos se aplicarán a toda la página web */
  html {
    font-family: system-ui, sans-serif;
    background-color: #ffffff;
    color: #333333;
  }
  body {
    margin: 0;
    padding: 0;
  }
  * {
    box-sizing: border-box; /* El truco del Box Model que vimos antes */
  }
</style>